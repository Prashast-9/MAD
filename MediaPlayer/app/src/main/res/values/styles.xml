<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Widget.MediaPlayer.ModeToggle" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">999dp</item>
    </style>

    <style name="Widget.MediaPlayer.ControlButton" parent="Widget.Material3.Button.TonalButton">
        <item name="android:minHeight">@dimen/playback_button_size</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:gravity">center</item>
        <item name="iconGravity">top</item>
        <item name="iconPadding">6dp</item>
        <item name="android:textAppearance">@style/TextAppearance.Material3.LabelSmall</item>
    </style>
</resources>
